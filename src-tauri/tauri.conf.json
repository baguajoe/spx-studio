{
  "productName": "SPX Studio",
  "version": "1.0.0",
  "identifier": "com.streampirex.spxstudio",
  "build": {
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3002",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "SPX Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "identifier": "com.streampirex.spxstudio",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
